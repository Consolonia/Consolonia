<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialog="clr-namespace:Consolonia.Modal"
        xmlns:brushes="https://github.com/consolonia">
    <StyleInclude Source="avares://Consolonia.Modal/Themes/DialogWindowTemplate.axaml" />
    <Styles.Resources>
        <ResourceDictionary>
            <brushes:LineBrush x:Key="DialogWindowBorderBrush"
                               LineStyle="Edge"
                               Brush="{DynamicResource ThemeBorderBrush}" />
            <ControlTheme x:Key="{x:Type dialog:DialogWindow}"
                          TargetType="dialog:DialogWindow"
                          BasedOn="{StaticResource {x:Type dialog:DialogWindow}}">
                <Setter Property="BorderBrush"
                        Value="{StaticResource DialogWindowBorderBrush}" />
            </ControlTheme>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>