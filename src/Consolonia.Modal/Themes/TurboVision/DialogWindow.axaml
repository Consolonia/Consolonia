<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialog="clr-namespace:Consolonia.Modal"
        xmlns:brushes="https://github.com/consolonia">
    <StyleInclude Source="avares://Consolonia.Modal/Themes/DialogWindowTemplate.axaml" />
    <Style Selector=":is(dialog|DialogWindow)">
        <Setter Property="BorderBrush">
            <Setter.Value>
                <brushes:LineBrush LineStyle="DoubleLine"
                                   Brush="{DynamicResource ThemeBorderBrush}" />
            </Setter.Value>
        </Setter>
    </Style>
</Styles>