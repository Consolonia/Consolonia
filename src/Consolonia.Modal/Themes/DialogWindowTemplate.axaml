<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialog="clr-namespace:Consolonia.Modal"
        xmlns:brushes="https://github.com/consolonia">
    <Style Selector=":is(dialog|DialogWindow)">
        <Style.Resources>
            <Thickness x:Key="ConsoloniaDialogWindowBorderMargin">1,0</Thickness>
        </Style.Resources>
        <Setter Property="Background"
                Value="{DynamicResource ThemeBackgroundBrush}" />
        <Setter Property="Foreground"
                Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Margin"
                Value="0" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="IsCloseButtonVisible"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="dialog:DialogWindow">
                    <Panel>
                        <!--Centered layout-->
                        <!--Panel shade Mode=Shaded-->
                        <Border Background="{DynamicResource ThemeShadeBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                            <Border BorderBrush="{DynamicResource ThemeTransparentBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}">
                                <Control
                                    Width="{Binding Path=ContentSize.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding Path=ContentSize.Height, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Border>

                        <!--Panel-->
                        <Panel Background="{TemplateBinding Background}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                            <Border BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <Control
                                    Width="{Binding Path=ContentSize.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding Path=ContentSize.Height, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}" />
                            </Border>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}"
                                        ZIndex="10"
                                        Orientation="Horizontal">
                                <brushes:SymbolsControl Text=" "
                                                        Foreground="{TemplateBinding BorderBrush}" />
                                <TextBlock Text="{TemplateBinding Title}"
                                           Foreground="{TemplateBinding Foreground}" />
                                <brushes:SymbolsControl Text=" "
                                                        Foreground="{TemplateBinding BorderBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        ZIndex="10"
                                        VerticalAlignment="Top"
                                        Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}"
                                        IsVisible="{TemplateBinding IsCloseButtonVisible}">
                                <StackPanel.Styles>
                                    <Style Selector="Button">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource ThemeActionBackgroundBrush}" />
                                        <Setter Property="IsTabStop"
                                                Value="False" />
                                        <Setter Property="Theme"
                                                Value="{DynamicResource ThemeNakedButton}" />
                                    </Style>
                                    <Style Selector="brushes|SymbolsControl">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource ThemeBorderBrush}" />
                                    </Style>
                                </StackPanel.Styles>
                                <DockPanel Margin="2,0,0,0">
                                    <brushes:SymbolsControl DockPanel.Dock="Left"
                                                            Text="[" />
                                    <brushes:SymbolsControl DockPanel.Dock="Right"
                                                            Text="]" />
                                    <Button Content="■"
                                            x:Name="PART_CloseButton"
                                            Command="{Binding Path=CloseClick, RelativeSource={RelativeSource TemplatedParent}}" />
                                </DockPanel>
                            </StackPanel>
                        </Panel>
                        <Panel Margin="2,1,2,1">
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}"
                                              Padding="{TemplateBinding Padding}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Content="{TemplateBinding Content}"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Panel>
                    </Panel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</Styles>