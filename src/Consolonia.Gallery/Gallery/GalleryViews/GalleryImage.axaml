<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:Consolonia.Gallery.Gallery.GalleryViews"
             mc:Ignorable="d"
             x:Class="Consolonia.Gallery.Gallery.GalleryViews.GalleryImage">
    <UserControl.Resources>
        <local:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <Button Grid.Row="0"
                HorizontalAlignment="Center"
                Margin="1"
                Content="Open Image..."
                Click="Button_Click" />

        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*,Auto"
              Margin="1">
            <Button Grid.Column="0"
                    Margin="1"
                    Content="&lt;"
                    Click="PrevButton_Click" />
            <TextBlock x:Name="ImageTitle"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2"
                    Margin="1"
                    Content="&gt;"
                    Click="NextButton_Click" />
        </Grid>

        <Border Grid.Row="2"
                Margin="1">
            <Carousel x:Name="ImageCarousel"
                      ItemsSource="{Binding ImagePaths}"
                      PageTransition="{x:Null}">
                <Carousel.ItemTemplate>
                    <DataTemplate>
                        <Image HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Source="{Binding Converter={StaticResource ImagePathToBitmapConverter}}"
                               Stretch="Uniform" />
                    </DataTemplate>
                </Carousel.ItemTemplate>
            </Carousel>
        </Border>
    </Grid>

</UserControl>